# Copy this file to .env in this same directory and fill in your own values,
# then run `pnpm dev` (see src/server.ts). `.env` is gitignored — never
# commit real credentials.
#
# This is only needed to run the traditional Node server locally
# (`pnpm dev` / `pnpm start`). Building and typechecking this app never
# need any of this. When deploying to Vercel, set these same three
# variables in the project's Environment Variables settings instead of
# using a .env file — see api/cognition.ts and README.md.

# Your Supabase project's URL and service-role key, running the
# `intelligence` schema (see packages/intelligence-os/src/db/schema.sql
# and its migrations). Find both in your Supabase dashboard under
# Settings → API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# An arbitrary shared secret between this service and its callers (e.g.
# BrandOS's HttpCognitionProvider) — a bearer token, not a keypair. Pick
# any string and set the exact same value on the calling side as
# INTELLIGENCE_OS_API_KEY. One way to generate a random one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COGNITION_API_KEY=change-me-to-a-random-shared-secret

# Optional — HTTP port for the traditional server (src/server.ts). Not
# used by the Vercel deployment (api/cognition.ts), which has no fixed
# port. Defaults to 4100.
PORT=4100
