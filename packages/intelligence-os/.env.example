# Copy this file to .env in this same directory and fill in your own values,
# then run `pnpm serve` (see src/dev/serve.ts). `.env` is gitignored — never
# commit real credentials.
#
# This is only needed to run the dev HTTP server (`pnpm serve`) locally.
# Installing, building, typechecking, and testing this package never need
# any of this — every Supabase call in the test suite is mocked (see
# INTELLIGENCEOS_BOOTSTRAP.md and this package's own README).

# Your Supabase project's URL and service-role key, running the
# `intelligence` schema (see src/db/schema.sql and src/db/migrations/).
# Find both in your Supabase dashboard under Settings → API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# An arbitrary shared secret between this service and BrandOS — a bearer
# token, not a keypair. Pick any string and set the exact same value as
# BrandOS's INTELLIGENCE_OS_API_KEY (see Engineering/PLATFORM_INTEGRATION.md
# at the platform root). One way to generate a random one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COGNITION_API_KEY=change-me-to-a-random-shared-secret

# Optional — HTTP port for the CognitionProvider API. Defaults to 4100.
PORT=4100
