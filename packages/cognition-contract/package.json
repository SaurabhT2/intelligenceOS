{
  "name": "@platform/cognition-contract",
  "version": "1.1.0",
  "description": "Zero-dependency cross-platform system contract between BrandOS (Execution Platform) and IntelligenceOS (Cognitive Platform). Types only — no runtime logic. This is the IntelligenceOS-repo copy; see README.md for the physical-duplication rule this package operates under.",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "check:parity": "node scripts/check-contract-parity.mjs",
    "clean": "rimraf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
